## Docker / PocketBase container admin bootstrap
PB_ADMIN_EMAIL=admin@example.com
PB_ADMIN_PASSWORD=change-me

## PocketBase type generation
PB_TYPEGEN_URL=http://127.0.0.1:8090
# Optional: falls back to PB_ADMIN_EMAIL / PB_ADMIN_PASSWORD when omitted.
# PB_TYPEGEN_EMAIL=admin@example.com
# PB_TYPEGEN_PASSWORD=change-me
# Or use a superuser impersonation token instead of email/password:
# PB_TYPEGEN_TOKEN=

## PocketBase seed
# Optional: falls back to PB_TYPEGEN_* and then PB_ADMIN_* when omitted.
PB_SEED_URL=http://127.0.0.1:8090
# PB_SEED_EMAIL=admin@example.com
# PB_SEED_PASSWORD=change-me
# Or use a superuser impersonation token instead of email/password:
# PB_SEED_TOKEN=
